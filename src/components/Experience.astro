---
import { getCollection } from "astro:content";

const experiencesEntries = await getCollection("experience");
const experiences = experiencesEntries.map((e: any) => e.data);
---

<section
    id="experience"
    class="relative min-h-screen bg-brand-bg py-16 md:py-24 px-6 md:px-12 overflow-hidden border-t border-brand-text/5"
>
    <!-- Background Large Typography -->
    <div
        class="absolute inset-0 w-full flex justify-center pointer-events-none select-none z-0"
    >
        <div class="h-screen flex items-center justify-center sticky top-0" id="experience-bg-container">
            <span
                class="text-[14vw] font-bold text-brand-text/5 leading-none uppercase"
                id="experience-bg-text"
            >
                EXPERIENCE
            </span>
        </div>
    </div>

    <div class="max-w-7xl mx-auto relative z-10">
        <!-- Section Header -->
        <div
            class="flex flex-col md:flex-row md:items-end justify-between mb-32 gap-8"
        >
            <div class="overflow-hidden">
                <h2
                    class="text-brand-accent mb-4 tracking-[0.5em] uppercase"
                    id="experience-tag"
                >
                    03 / CAREER LINEAGE
                </h2>
                <h3
                    class="text-6xl md:text-8xl font-bold leading-none tracking-widest uppercase"
                    id="experience-title"
                >
                    PROFESSIONAL <br /> HISTORY
                </h3>
            </div>
            <div class="md:text-right max-w-xs overflow-hidden">
                <p
                    class="text-[11px] leading-relaxed text-brand-text/50 uppercase tracking-widest"
                    id="experience-info"
                >
                    A Narrative of Technical Growth, Project Mastery, and 
                    Strategic Problem Solving.
                </p>
            </div>
        </div>

        <!-- Career Timeline -->
        <div class="space-y-40">
            {
                experiences.map((exp: any, index: number) => (
                    <div class="experience-item group grid grid-cols-1 md:grid-cols-12 gap-8 items-start">
                        <!-- Left: Date Marker -->
                        <div class="md:col-span-3 pt-2">
                            <span class="text-[13px] font-bold tracking-[0.3em] text-brand-accent uppercase block h-fit border-l-2 border-brand-accent/30 pl-4 py-1">
                                {exp.period}
                            </span>
                            {exp.isCurrent && (
                                <span class="inline-block mt-4 px-3 py-1 bg-brand-accent/10 rounded-full text-[9px] font-bold tracking-widest text-brand-accent animate-pulse uppercase">
                                    CURRENT
                                </span>
                            )}
                        </div>

                        <!-- Right: Content -->
                        <div class="md:col-span-9 space-y-8">
                            <div class="space-y-2">
                                <h4 class="text-4xl md:text-7xl font-bold tracking-wide text-brand-text group-hover:text-brand-accent transition-colors duration-500">
                                    {exp.role}
                                </h4>
                                <p class="text-xl md:text-2xl font-serif italic text-brand-text/50">
                                    {exp.company}
                                </p>
                            </div>

                            <div class="max-w-4xl relative">
                                <div class="absolute -left-6 top-0 bottom-0 w-px bg-brand-text/10" />
                                <p class="text-lg md:text-2xl leading-relaxed text-brand-text/70 font-medium pl-6">
                                    "{exp.narrative}"
                                </p>
                            </div>

                            <!-- Skill Tags -->
                            <div class="flex flex-wrap gap-3">
                                {exp.skills.map((skill: string) => (
                                    <span class="px-4 py-2 bg-brand-accent/10 border border-brand-accent/20 rounded-full text-[10px] font-bold tracking-widest text-brand-accent hover:bg-brand-accent hover:text-brand-bg transition-all duration-300 uppercase leading-none">
                                        {skill}
                                    </span>
                                ))}
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    window.addEventListener("DOMContentLoaded", () => {
        // 1. Entrance Reveal
        const experienceSections = ["#experience-tag", "#experience-title", "#experience-info"];
        const expTl = gsap.timeline({
            scrollTrigger: {
                trigger: "#experience",
                start: "top 70%",
            },
        });

        expTl.from(experienceSections, {
            y: 40,
            opacity: 0,
            stagger: 0.2,
            duration: 1.2,
            ease: "power3.out",
        });

        // 2. Row Stagger (Sequential Reveal)
        gsap.from(".experience-item", {
            scrollTrigger: {
                trigger: "#experience",
                start: "top 60%",
            },
            y: 50,
            opacity: 0,
            stagger: 0.3,
            duration: 1.5,
            ease: "power3.out",
        });

        // 3. Background Sticky Text (Lag Scrub)
        gsap.to("#experience-bg-text", {
            scrollTrigger: {
                trigger: "#experience",
                start: "top top",
                end: "bottom bottom",
                scrub: 1.5,
            },
            y: 100,
            ease: "none",
        });
    });
</script>
