---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: URL | string;
  type?: "website" | "article";
}

const {
  title = "Nasrullah Gunawan | Full-Stack Developer & AI Specialist",
  description = "Professional Full-Stack Web Developer specialized in Laravel, Next.js, and AI Integration. Providing premium web development services and SaaS architecture in Indonesia and worldwide.",
  image = "/og-image.png", // Make sure this exists or user provides one
  canonicalURL = new URL(Astro.url.pathname, Astro.site),
  type = "website",
} = Astro.props;

const siteName = "NanasLab";
const twitterHandle = "@nasgunawann"; // Assuming from context or generic
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta
  name="keywords"
  content="Web Developer, Jasa Buat Aplikasi, Laravel Expert, Next.js Specialist, AI Integration, SaaS Development, Indonesia, Software House, NanasLab, Ananas Digital, Nanasgunung Creative Studio, Nasrullah Gunawan"
/>

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />
<meta property="og:site_name" content={siteName} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, Astro.url)} />
{twitterHandle && <meta property="twitter:site" content={twitterHandle} />}

<!-- Structured Data (JSON-LD) -->
<script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Nasrullah Gunawan",
    "url": "https://nanaslab.com",
    "image": "https://nanaslab.com/nasgun_portrait.png",
    "sameAs": [
      "https://github.com/nasgunawann",
      "https://linkedin.com/in/nasgunawan"
    ],
    "jobTitle": "Full-Stack Web Developer",
    "description": "Specialist in Laravel, Next.js, and AI Integration.",
    "knowsAbout": [
      "Web Development",
      "Laravel",
      "Next.js",
      "Artificial Intelligence",
      "SaaS Architecture"
    ]
  }
</script>

<script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Nanaslab",
    "url": "https://nanaslab.com",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://nanaslab.com/?s={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
</script>
