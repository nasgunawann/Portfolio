---
const skillCategories = [
  {
    name: 'Frontend',
    skills: ['HTML5', 'CSS3/Sass', 'JavaScript (ES6+)', 'TypeScript', 'React', 'Vue.js', 'Next.js', 'Astro', 'Tailwind CSS'],
  },
  {
    name: 'Backend & Tools',
    skills: ['Node.js', 'Express', 'PostgreSQL', 'MongoDB', 'GraphQL', 'Git/GitHub', 'Docker', 'Vite', 'Webpack'],
  },
  {
    name: 'Design & UX',
    skills: ['Figma', 'Adobe XD', 'User Experience', 'Prototyping', 'Responsive Design', 'Accessibility'],
  },
];
---

<section id="skills" class="py-24 px-6 bg-zinc-900">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-white mb-4">Core Competencies</h2>
      <p class="text-zinc-400 max-w-2xl mx-auto">
        These are the core technologies and tools I use to bring ideas to life.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      {skillCategories.map((category) => (
        <div class="flex flex-col gap-6 p-8 rounded-2xl bg-zinc-950 border border-white/5 hover:border-brand-accent/30 transition-all duration-300">
          <h3 class="text-xl font-bold text-brand-accent tracking-wide uppercase">
            {category.name}
          </h3>
          <ul class="flex flex-wrap gap-2 text-zinc-300 list-none p-0">
            {category.skills.map((skill) => (
              <li class="px-4 py-2 border border-white/10 rounded-lg bg-zinc-900 group-hover:bg-zinc-800 transition-colors">
                {skill}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
