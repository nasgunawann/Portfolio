---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { IconExternalLink, IconFileDownload } from "@tabler/icons-react";

const educationEntries = await getCollection("education");
const formalEducation = educationEntries.map((e: any) => e.data);

const certsEntries = await getCollection("certifications");
const certifications = certsEntries.map((c: any) => c.data);
---

<section
    id="credentials"
    class="relative min-h-screen bg-brand-bg py-24 md:py-40 px-6 md:px-12 overflow-hidden border-t border-brand-text/5"
>
    <!-- Background Large Typography (Decorative) -->
    <div
        class="absolute inset-0 w-full flex justify-center pointer-events-none select-none z-0"
    >
        <div class="h-screen flex items-center justify-center sticky top-0" id="credentials-bg-container">
            <span
                class="text-[17vw] font-bold text-brand-text/5 leading-none uppercase"
                id="credentials-bg-text"
            >
                ACADEMIA
            </span>
        </div>
    </div>

    <div class="max-w-7xl mx-auto relative z-10">
        <!-- Section Header -->
        <div
            class="flex flex-col md:flex-row md:items-end justify-between mb-32 gap-8"
        >
            <div class="overflow-hidden">
                <h2
                    class="text-brand-accent mb-4 tracking-[0.5em] uppercase"
                    id="credentials-tag"
                >
                    04 / CREDENTIALS
                </h2>
                <h3
                    class="text-6xl md:text-8xl font-bold leading-none tracking-widest uppercase"
                    id="credentials-title"
                >
                    ACADEMIC <br /> FOUNDATION
                </h3>
            </div>
            <div class="md:text-right max-w-xs overflow-hidden">
                <p
                    class="text-[11px] leading-relaxed text-brand-text/50 uppercase tracking-widest"
                    id="credentials-info"
                >
                    A Synthesis of Formal Systems Education and Modern Cloud 
                    Specializations.
                </p>
            </div>
        </div>

        <div class="space-y-40">
            <!-- 04.1 Formal Education (Institutional Style) -->
            <div class="space-y-20 section-formal relative">
                <!-- Continuous Timeline Line -->
                <div 
                    class="absolute left-0 top-0 bottom-0 w-px bg-brand-text/10 hidden md:block origin-top" 
                    id="education-timeline-line"
                ></div>

                <div class="flex items-center gap-6">
                    <span class="text-[11px] font-bold tracking-[0.5em] text-brand-accent uppercase md:pl-12">
                        04.1 / Academic Degrees
                    </span>
                    <div class="h-px flex-1 bg-brand-text/10"></div>
                </div>

                <div class="space-y-24">
                    {
                        formalEducation.map((item: any) => (
                            <div class="credential-item group grid grid-cols-1 md:grid-cols-12 gap-8 items-start relative">
                                <!-- Year & Type -->
                                <div class="md:col-span-3 pt-2 relative">
                                    <!-- Technical Tick -->
                                    <div class="absolute left-0 top-6 w-8 h-px bg-brand-accent/30 hidden md:block"></div>

                                    <span class="text-[13px] font-bold tracking-[0.3em] text-brand-accent uppercase block h-fit md:pl-12 py-1">
                                        {item.period}
                                    </span>
                                </div>
                                
                                <!-- Content -->
                                <div class="md:col-span-9 space-y-8">
                                    <div class="space-y-2">
                                        <h4 class="text-4xl md:text-7xl font-bold text-brand-text group-hover:text-brand-accent transition-colors duration-500">
                                            {item.title}
                                        </h4>
                                        <p class="text-xl md:text-2xl font-serif italic text-brand-text/50">
                                            {item.institution}
                                        </p>
                                    </div>

                                    <div class="max-w-4xl relative">
                                        <div class="absolute -left-6 top-0 bottom-0 w-px bg-brand-text/10" />
                                        <p class="text-lg md:text-2xl leading-relaxed text-brand-text/70 font-medium pl-6 italic">
                                            "{item.narrative}"
                                        </p>
                                    </div>

                                    <div class="flex flex-wrap gap-3 pt-4">
                                        {item.skills.map((skill: string) => (
                                            <span class="px-4 py-2 bg-brand-accent/10 border border-brand-accent/20 rounded-full text-[10px] font-bold tracking-widest text-brand-accent hover:bg-brand-accent hover:text-brand-bg transition-all duration-300 uppercase leading-none">
                                                {skill}
                                            </span>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>

            <!-- 04.2 Certifications (Technical Archive Style) -->
            <div class="space-y-20 section-certs">
                <div class="flex items-center gap-6">
                    <span class="text-[11px] font-bold tracking-[0.5em] text-brand-accent uppercase">
                        04.2 / Technical Certifications
                    </span>
                    <div class="h-px flex-1 bg-brand-text/10"></div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    {
                        certifications.map((item: any) => (
                            <div class="credential-item-compact group p-8 border border-brand-text/5 rounded-[2.5rem] bg-brand-text/1 hover:bg-brand-accent/5 hover:border-brand-accent/20 transition-all duration-500 flex flex-col justify-between h-full relative overflow-hidden">
                                <div class="space-y-6 relative z-10">
                                    <div class="space-y-2">
                                        <h4 class="text-xl md:text-2xl font-bold text-brand-text group-hover:text-brand-accent transition-colors">
                                            {item.title}
                                        </h4>
                                        <div class="flex items-center justify-between">
                                            <p class="text-[10px] font-bold tracking-widest text-brand-text/40 uppercase">
                                                {item.institution}
                                            </p>
                                            {item.isCurrent && (
                                                <span class="text-[9px] font-bold text-brand-accent animate-pulse tracking-widest uppercase bg-brand-accent/10 px-2 py-0.5 rounded">
                                                    LIVE
                                                </span>
                                            )}
                                        </div>
                                    </div>
                                    
                                    <p class="text-[12px] leading-relaxed text-brand-text/60 font-medium font-mono py-1">
                                        {item.technicalNote}
                                    </p>

                                    <!-- Certificate Preview -->
                                    <div class="relative group/cert h-fit mt-2">
                                        <div class="aspect-16/10 w-full bg-brand-text/5 rounded-2xl border border-brand-text/5 flex items-center justify-center group-hover:bg-brand-accent/5 group-hover:border-brand-accent/10 transition-all overflow-hidden">
                                            {item.isCurrent ? (
                                                <span class="text-[10px] font-bold text-brand-accent animate-pulse uppercase tracking-[0.4em]">IN PROGRESS</span>
                                            ) : item.image ? (
                                                <Image 
                                                    src={item.image} 
                                                    alt={item.title}
                                                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                                                />
                                            ) : (
                                                <span class="text-[8px] font-bold text-brand-text/20 uppercase tracking-[0.3em] group-hover:text-brand-accent/30">Preview Credential</span>
                                            )}
                                        </div>

                                        {!item.isCurrent && item.link && (
                                            <a 
                                                href={item.link}
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                class="absolute bottom-4 right-4 inline-flex items-center gap-2 px-4 py-2.5 bg-brand-text text-brand-bg rounded-full text-[9px] font-bold tracking-widest uppercase hover:bg-brand-accent hover:scale-110 transition-all duration-300 shadow-2xl z-20"
                                            >
                                                {item.linkType === 'pdf' ? (
                                                    <>
                                                        <IconFileDownload size={14} stroke={2.5} />
                                                        PDF
                                                    </>
                                                ) : (
                                                    <>
                                                        <IconExternalLink size={14} stroke={2.5} />
                                                        VERIFY
                                                    </>
                                                )}
                                            </a>
                                        )}
                                    </div>
                                </div>
                                
                                <div class="flex flex-wrap gap-2 pt-8">
                                    <div class="flex flex-wrap gap-2">
                                        {item.skills.map((skill: string) => (
                                            <span class="px-3 py-1.5 bg-brand-accent/5 border border-brand-accent/10 rounded-full text-[9px] font-bold tracking-widest text-brand-text hover:text-brand-bg hover:bg-brand-accent hover:border-brand-accent transition-all duration-300 uppercase leading-none">
                                               {skill}
                                            </span>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    function initCredentials() {
        // 1. Header Entrance
        const headerElements = [
            "#credentials-tag",
            "#credentials-title",
            "#credentials-info",
        ];
        
        gsap.from(headerElements, {
            scrollTrigger: {
                trigger: "#credentials",
                start: "top 80%",
            },
            y: 30,
            opacity: 0,
            stagger: 0.15,
            duration: 1,
            ease: "power3.out",
        });

        // 2. Timeline Line Drawing
        gsap.from("#education-timeline-line", {
            scrollTrigger: {
                trigger: ".section-formal",
                start: "top 70%",
                end: "bottom 60%",
                scrub: 1,
            },
            scaleY: 0,
            ease: "none",
        });

        // 3. Items Entrance (Already defined via section or can be reinforced)
        
        // 3. Background Sticky Text with Lag
        gsap.to("#credentials-bg-text", {
            scrollTrigger: {
                trigger: "#credentials",
                start: "top top",
                end: "bottom bottom",
                scrub: 1.5,
            },
            y: 100,
            ease: "none",
        });
    }

    // Initialize
    initCredentials();

    // Refresh on full page load to ensure positions are correct
    window.addEventListener("load", () => {
        ScrollTrigger.refresh();
    });
</script>
