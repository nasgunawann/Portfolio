---
const formalEducation = [
    {
        title: "Sistem Informasi (S1)",
        institution: "Universitas Islam Negeri Sumatera Utara",
        period: "2023 - Present",
        location: "Medan, ID",
        narrative: "Currently pursuing my Bachelor's degree, I focus on the intersection of technical architecture and financial optimization. My academic tenure is dedicated to exploring AI-driven personal finance systems and implementing Agile methodologies for large-scale campus platforms.",
        skills: ["System Analysis", "Database Design", "Agile Methodologies"],
    }
];

const certifications = [
    {
        title: "AWS Re/Start Cloud Trainee",
        institution: "Orbit Future Academy",
        period: "Mar 2026 - Present",
        technicalNote: "Selected for an intensive 12-week program focusing on AWS Architecture (EC2, S3, RDS, VPC), network security, and scalable cloud deployments.",
        skills: ["Cloud Architecture", "VPC", "Security Protocols"],
        isCurrent: true
    },
    {
        title: "Fundamental Project Management",
        institution: "KOMDIGI & Google",
        period: "Issued Aug 2025",
        technicalNote: "Specialized training via Fresh Graduate Academy (DTS) focusing on SDLC and strategic project management methodologies.",
        skills: ["Project Management", "SDLC", "Strategy"],
    },
    {
        title: "Student Developer Initiative",
        institution: "Hacktiv8 Indonesia",
        period: "Issued Oct 2025",
        technicalNote: "Advanced program focused on Code Generation and Optimization techniques to improve development efficiency.",
        skills: ["Code Optimization", "Code Generation", "Performance"],
    },
    {
        title: "Intro to Generative AI",
        institution: "Amazon Web Services (AWS)",
        period: "Issued Mar 2026",
        technicalNote: "Training badge for foundational Generative AI concepts and deployment within the AWS ecosystem.",
        skills: ["Generative AI", "AWS AI Services", "LLMs"],
    },
    {
        title: "Gen AI Apps with Microsoft Azure",
        institution: "Dicoding Indonesia",
        period: "Issued Mar 2026",
        technicalNote: "Implementation of Large Language Models (LLM) and Generative AI application development on Azure.",
        skills: ["Azure Cloud", "LLM", "Generative AI"],
    },
    {
        title: "Data Science with Microsoft Fabric",
        institution: "Dicoding Indonesia",
        period: "Issued Mar 2026",
        technicalNote: "Advanced data analytics and data science application using the Microsoft Fabric platform.",
        skills: ["Data Analytics", "Data Science", "Microsoft Fabric"],
    },
    {
        title: "IBM Granite: Code Optimization",
        institution: "IBM",
        period: "Issued Sep 2025",
        technicalNote: "Specialized training in utilizing IBM Granite models for code generation and algorithmic optimization.",
        skills: ["IBM Granite", "Code Optimization", "AI Tools"],
    }
];
---

<section
    id="credentials"
    class="relative min-h-screen bg-brand-bg py-24 md:py-40 px-6 md:px-12 overflow-hidden border-t border-brand-text/5"
>
    <!-- Background Large Typography (Decorative) -->
    <div
        class="absolute inset-0 w-full flex justify-center pointer-events-none select-none z-0"
    >
        <div class="h-screen flex items-center justify-center sticky top-0" id="credentials-bg-container">
            <span
                class="text-[17vw] font-bold text-brand-text/5 leading-none uppercase"
                id="credentials-bg-text"
            >
                ACADEMIA
            </span>
        </div>
    </div>

    <div class="max-w-7xl mx-auto relative z-10">
        <!-- Section Header -->
        <div
            class="flex flex-col md:flex-row md:items-end justify-between mb-32 gap-8"
        >
            <div class="overflow-hidden">
                <h2
                    class="text-brand-accent mb-4 tracking-[0.5em] uppercase"
                    id="credentials-tag"
                >
                    04 / CREDENTIALS
                </h2>
                <h3
                    class="text-6xl md:text-8xl font-bold leading-none tracking-widest uppercase"
                    id="credentials-title"
                >
                    ACADEMIC <br /> FOUNDATION
                </h3>
            </div>
            <div class="md:text-right max-w-xs overflow-hidden">
                <p
                    class="text-[11px] leading-relaxed text-brand-text/50 uppercase tracking-widest"
                    id="credentials-info"
                >
                    A Synthesis of Formal Systems Education and Modern Cloud 
                    Specializations.
                </p>
            </div>
        </div>

        <div class="space-y-40">
            <!-- 04.1 Formal Education (Institutional Style) -->
            <div class="space-y-20 section-formal">
                <div class="flex items-center gap-6">
                    <span class="text-[11px] font-bold tracking-[0.5em] text-brand-accent uppercase">
                        04.1 / Academic Degrees
                    </span>
                    <div class="h-px flex-1 bg-brand-text/10"></div>
                </div>

                <div class="space-y-24">
                    {
                        formalEducation.map((item) => (
                            <div class="credential-item group grid grid-cols-1 md:grid-cols-12 gap-8 items-start">
                                <!-- Year & Type -->
                                <div class="md:col-span-3 pt-2">
                                    <span class="text-[13px] font-bold tracking-[0.3em] text-brand-accent uppercase block h-fit border-l-2 border-brand-accent/30 pl-4 py-1">
                                        {item.period}
                                    </span>
                                </div>
                                
                                <!-- Content -->
                                <div class="md:col-span-9 space-y-8">
                                    <div class="space-y-2">
                                        <h4 class="text-4xl md:text-7xl font-bold text-brand-text group-hover:text-brand-accent transition-colors duration-500">
                                            {item.title}
                                        </h4>
                                        <p class="text-xl md:text-2xl font-serif italic text-brand-text/50">
                                            {item.institution}
                                        </p>
                                    </div>

                                    <div class="max-w-4xl relative">
                                        <div class="absolute -left-6 top-0 bottom-0 w-px bg-brand-text/10" />
                                        <p class="text-lg md:text-2xl leading-relaxed text-brand-text/70 font-medium pl-6 italic">
                                            "{item.narrative}"
                                        </p>
                                    </div>

                                    <div class="flex flex-wrap gap-3 pt-4">
                                        {item.skills.map((skill) => (
                                            <span class="px-4 py-2 bg-brand-accent/10 border border-brand-accent/20 rounded-full text-[10px] font-bold tracking-widest text-brand-accent hover:bg-brand-accent hover:text-brand-bg transition-all duration-300 uppercase leading-none">
                                                {skill}
                                            </span>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>

            <!-- 04.2 Certifications (Technical Archive Style) -->
            <div class="space-y-20 section-certs">
                <div class="flex items-center gap-6">
                    <span class="text-[11px] font-bold tracking-[0.5em] text-brand-accent uppercase">
                        04.2 / Technical Certifications
                    </span>
                    <div class="h-px flex-1 bg-brand-text/10"></div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    {
                        certifications.map((item) => (
                            <div class="credential-item-compact group p-8 border border-brand-text/5 rounded-[2.5rem] bg-brand-text/1 hover:bg-brand-accent/5 hover:border-brand-accent/20 transition-all duration-500 flex flex-col justify-between h-full relative overflow-hidden">
                                <div class="space-y-6 relative z-10">
                                    <div class="space-y-2">
                                        <h4 class="text-xl md:text-2xl font-bold text-brand-text group-hover:text-brand-accent transition-colors">
                                            {item.title}
                                        </h4>
                                        <div class="flex items-center justify-between">
                                            <p class="text-[10px] font-bold tracking-widest text-brand-text/40 uppercase">
                                                {item.institution}
                                            </p>
                                            {item.isCurrent && (
                                                <span class="text-[9px] font-bold text-brand-accent animate-pulse tracking-widest uppercase bg-brand-accent/10 px-2 py-0.5 rounded">
                                                    LIVE
                                                </span>
                                            )}
                                        </div>
                                    </div>
                                    
                                    <p class="text-[12px] leading-relaxed text-brand-text/60 font-medium font-mono py-1">
                                        {item.technicalNote}
                                    </p>

                                    <!-- Certificate Preview Placeholder -->
                                    <div class="aspect-16/10 w-full bg-brand-text/5 rounded-2xl border border-brand-text/5 flex items-center justify-center group-hover:bg-brand-accent/5 group-hover:border-brand-accent/10 transition-all mt-2">
                                        <span class="text-[8px] font-bold text-brand-text/20 uppercase tracking-[0.3em] group-hover:text-brand-accent/30">Preview Credential</span>
                                    </div>
                                </div>
                                
                                <div class="flex flex-wrap gap-2 pt-8">
                                    {item.skills.map((skill) => (
                                        <span class="px-3 py-1.5 bg-brand-accent/5 border border-brand-accent/10 rounded-full text-[9px] font-bold tracking-widest text-brand-text hover:text-brand-bg hover:bg-brand-accent hover:border-brand-accent transition-all duration-300 uppercase leading-none">
                                           {skill}
                                        </span>
                                    ))}
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    function initCredentials() {
        // 1. Header Entrance
        const headerElements = [
            "#credentials-tag",
            "#credentials-title",
            "#credentials-info",
        ];
        
        gsap.from(headerElements, {
            scrollTrigger: {
                trigger: "#credentials",
                start: "top 80%",
            },
            y: 30,
            opacity: 0,
            stagger: 0.15,
            duration: 1,
            ease: "power3.out",
        });

        // 2. Items are now static for better performance and reliability
        
        // 3. Background Sticky Text with Lag
        gsap.to("#credentials-bg-text", {
            scrollTrigger: {
                trigger: "#credentials",
                start: "top top",
                end: "bottom bottom",
                scrub: 1.5,
            },
            y: 100,
            ease: "none",
        });
    }

    // Initialize
    initCredentials();

    // Refresh on full page load to ensure positions are correct
    window.addEventListener("load", () => {
        ScrollTrigger.refresh();
    });
</script>
