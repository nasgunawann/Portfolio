---
const projects = [
  {
    title: 'Modern E-Commerce',
    description: 'A fully responsive e-commerce platform with a clean design and smooth animations.',
    tags: ['Astro', 'Tailwind CSS', 'React'],
    link: '#',
  },
  {
    title: 'SAAS Dashboard',
    description: 'An interactive dashboard with data visualization and glassmorphism effects.',
    tags: ['Astro', 'Chart.js', 'Tailwind CSS'],
    link: '#',
  },
  {
    title: 'Real Estate Platform',
    description: 'A premium real estate listing site with advanced search filtering.',
    tags: ['Tailwind CSS', 'Alpine.js', 'Astro'],
    link: '#',
  },
];
---

<section id="projects" class="py-24 px-6 bg-zinc-950">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-white mb-4">Featured Projects</h2>
      <p class="text-zinc-400 max-w-2xl mx-auto">
        Check out some of my recent work, designed with a focus on usability and beauty.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projects.map((project) => (
        <div class="group relative bg-zinc-900 border border-white/5 rounded-2xl overflow-hidden hover:border-brand-primary/50 transition-all duration-300">
          <div class="aspect-video bg-zinc-800 p-8 flex items-center justify-center">
            <!-- Project Placeholder Visual -->
            <div class="w-full h-full bg-linear-to-br from-brand-primary/20 via-brand-secondary/20 to-brand-accent/20 rounded-xl animate-pulse">
            </div>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-white mb-2 group-hover:text-brand-primary transition-colors">
              {project.title}
            </h3>
            <p class="text-zinc-400 text-sm mb-4">
              {project.description}
            </p>
            <div class="flex flex-wrap gap-2 mb-6">
              {project.tags.map((tag) => (
                <span class="px-3 py-1 bg-zinc-800 text-zinc-300 text-xs font-semibold rounded-full border border-white/5">
                  {tag}
                </span>
              ))}
            </div>
            <a
              href={project.link}
              class="inline-flex items-center text-brand-secondary font-bold text-sm hover:underline underline-offset-4"
            >
              View Project
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
