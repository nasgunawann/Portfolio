---
import nas from "@/assets/nasgun_nobg.png";
import SocialLinks from "@/components/SocialLinks";
import { IconArrowRight } from "@tabler/icons-react";
---

<section
    class="min-h-screen bg-brand-bg relative flex flex-col items-center justify-center px-6 overflow-hidden"
>
    <!-- Sticky Editorial Header (Scroll-Activated) -->
    <nav
        id="sticky-header"
        class="fixed top-0 left-0 w-full z-100 px-6 md:px-12 py-6 flex items-center justify-between bg-brand-bg/80 backdrop-blur-xl border-b border-brand-text/5 opacity-0 -translate-y-full transition-all duration-500"
    >
        <div class="flex items-center gap-12 text-editorial">
            <a
                href="#"
                class="hover:text-brand-accent transition-colors font-bold tracking-widest text-lg"
                >NASRULLAH GUNAWAN</a
            >
            <div class="hidden lg:flex items-center gap-10 opacity-70 ml-8">
                <a
                    href="#about"
                    class="text-[11px] font-bold hover:text-brand-accent hover:opacity-100 transition-all uppercase tracking-[0.3em] relative group flex items-center"
                >
                    <span
                        class="text-brand-accent opacity-0 group-hover:opacity-100 absolute -left-4 transition-opacity"
                        >/</span
                    >
                    Story
                </a>
                <a
                    href="#projects"
                    class="text-[11px] font-bold hover:text-brand-accent hover:opacity-100 transition-all uppercase tracking-[0.3em] relative group flex items-center"
                >
                    <span
                        class="text-brand-accent opacity-0 group-hover:opacity-100 absolute -left-4 transition-opacity"
                        >/</span
                    >
                    Works
                </a>
                <a
                    href="#experience"
                    class="text-[11px] font-bold hover:text-brand-accent hover:opacity-100 transition-all uppercase tracking-[0.3em] relative group flex items-center"
                >
                    <span
                        class="text-brand-accent opacity-0 group-hover:opacity-100 absolute -left-4 transition-opacity"
                        >/</span
                    >
                    Career
                </a>
                <a
                    href="#credentials"
                    class="text-[11px] font-bold hover:text-brand-accent hover:opacity-100 transition-all uppercase tracking-[0.3em] relative group flex items-center"
                >
                    <span
                        class="text-brand-accent opacity-0 group-hover:opacity-100 absolute -left-4 transition-opacity"
                        >/</span
                    >
                    Credentials
                </a>
            </div>
        </div>

        <div class="flex items-center gap-8">
            <div class="hidden md:flex items-center text-editorial">
                <a
                    href="#contact"
                    class="flex items-center gap-3 text-[11px] font-bold hover:text-brand-accent transition-colors uppercase tracking-[0.3em]"
                >
                    Let's Talk <span
                        class="w-1.5 h-1.5 rounded-full bg-brand-accent animate-pulse"
                    ></span>
                </a>
            </div>

            <!-- Mobile Menu Toggle -->
            <button
                id="mobile-menu-toggle"
                class="lg:hidden flex flex-col justify-center gap-2 w-8 h-8 focus:outline-none z-110"
            >
                <span
                    class="w-full h-[2px] bg-brand-text transition-all duration-300 origin-center"
                    id="bar1"></span>
                <span
                    class="w-full h-[2px] bg-brand-text transition-all duration-300 origin-center"
                    id="bar2"></span>
            </button>
        </div>
    </nav>

    <!-- Mobile Menu Overlay -->
    <div
        id="mobile-overlay"
        class="fixed inset-0 bg-brand-bg/95 backdrop-blur-2xl z-90 translate-x-full transition-transform duration-500 lg:hidden flex flex-col items-center justify-center gap-10"
    >
        <a
            href="#about"
            class="mobile-link text-3xl font-bold uppercase tracking-widest text-brand-text hover:text-brand-accent transition-colors"
            >Story</a
        >
        <a
            href="#projects"
            class="mobile-link text-3xl font-bold uppercase tracking-widest text-brand-text hover:text-brand-accent transition-colors"
            >Works</a
        >
        <a
            href="#experience"
            class="mobile-link text-3xl font-bold uppercase tracking-widest text-brand-text hover:text-brand-accent transition-colors"
            >Career</a
        >
        <a
            href="#credentials"
            class="mobile-link text-3xl font-bold uppercase tracking-widest text-brand-text hover:text-brand-accent transition-colors"
            >Credentials</a
        >
        <a
            href="#contact"
            class="mobile-link text-xl mt-8 flex items-center gap-4 font-bold uppercase tracking-widest text-brand-text hover:text-brand-accent transition-colors"
        >
            Let's Talk <span
                class="w-2 h-2 rounded-full bg-brand-accent animate-pulse"
            ></span>
        </a>
    </div>

    <!-- Main Content Layout -->
    <div
        class="relative w-full max-w-7xl mx-auto min-h-screen flex flex-col md:items-center md:justify-center pt-16 md:pt-0"
    >
        <!-- Large Background Text (Bebas Neue) -->
        <div
            class="relative md:absolute md:inset-0 flex flex-col items-center justify-center pointer-events-none select-none z-0 mb-8 md:mb-0"
        >
            <h1
                class="text-[18vw] md:text-[25vw] leading-[0.75] text-brand-text/50 text-center whitespace-nowrap"
            >
                <div class="overflow-hidden py-2">
                    <span class="inline-block opacity-0" id="name-line-1"
                        >NASRULLAH</span
                    >
                </div>
                <div class="overflow-hidden py-2">
                    <span class="inline-block opacity-0" id="name-line-2"
                        >GUNAWAN</span
                    >
                </div>
            </h1>
            <h2
                class="text-[11px] font-bold tracking-[0.5em] uppercase text-brand-accent mt-4 opacity-0"
                id="hero-subtitle"
            >
                Full-Stack Web Developer & AI Specialist
            </h2>

            <!-- Minimal CTA & Socials (Mobile Only) -->
            <div
                class="xl:hidden flex flex-col items-center gap-8 mt-8 mb-4 relative z-30 pointer-events-auto"
                id="mobile-content-stack"
            >
                <div class="opacity-0" id="mobile-cta">
                    <a
                        href="#contact"
                        class="px-8 py-4 border border-brand-text/20 bg-brand-bg/80 backdrop-blur-sm rounded-full text-[11px] font-bold tracking-[0.3em] uppercase hover:bg-brand-text hover:text-brand-bg transition-all inline-block shadow-lg"
                    >
                        <span class="flex items-center gap-2"
                            >LET'S TALK <IconArrowRight
                                size={16}
                                stroke={2}
                            /></span
                        >
                    </a>
                </div>

                <div
                    class="opacity-0 flex items-center justify-center"
                    id="mobile-socials"
                >
                    <SocialLinks className="gap-8" client:load />
                </div>
            </div>
        </div>

        <!-- Portrait Container (Responsive: Stacked on Mobile, Anchored on Desktop) -->
        <div
            class="relative md:absolute md:bottom-0 md:left-1/2 md:-translate-x-1/2 z-20 w-full max-w-2xl h-[50vh] md:h-[85vh] flex items-end justify-center pointer-events-none mt-auto"
        >
            <div
                class="w-full h-full relative group flex items-end justify-center pointer-events-auto"
            >
                <img
                    id="portrait-img"
                    src={nas.src}
                    alt="Nasrullah Gunawan"
                    class="w-auto h-full object-contain transition-all duration-1000 origin-bottom opacity-0 filter grayscale hover:grayscale-0"
                />
            </div>
        </div>

        <!-- Floating Minimal Links (Desktop Only) -->
        <div
            class="absolute left-12 bottom-24 hidden xl:flex flex-col gap-4 z-40 corner-block opacity-0"
        >
            <a
                href="#projects"
                class="px-8 py-4 border border-brand-text/20 bg-brand-bg/80 backdrop-blur-sm rounded-full text-[11px] font-bold tracking-[0.3em] uppercase hover:bg-brand-text hover:text-brand-bg transition-all inline-block shadow-lg w-fit text-center"
            >
                <span class="flex items-center gap-2 justify-center"
                    >VIEW PROJECTS <IconArrowRight size={16} stroke={2} /></span
                >
            </a>
            <a
                href="#contact"
                class="px-8 py-4 border border-brand-text/20 bg-brand-bg/80 backdrop-blur-sm rounded-full text-[11px] font-bold tracking-[0.3em] uppercase hover:bg-brand-text hover:text-brand-bg transition-all inline-block shadow-lg w-fit text-center"
            >
                <span class="flex items-center gap-2 justify-center"
                    >LET'S TALK <IconArrowRight size={16} stroke={2} /></span
                >
            </a>
        </div>

        <div
            class="absolute right-12 bottom-32 hidden xl:block z-30 corner-block opacity-0"
        >
            <SocialLinks className="gap-8" client:load />
        </div>
    </div>

    <!-- Bottom Marquee (Ticker) -->
    <div
        class="absolute bottom-0 left-0 w-full z-40 bg-brand-text text-brand-bg"
    >
        <div class="marquee-container border-none py-4! shadow-2xl">
            <div
                class="marquee-content gap-16 text-editorial font-bold! tracking-[0.5em]! text-[11px]!"
            >
                <span>FULL-STACK DEVELOPMENT</span>
                <span class="text-brand-secondary">✦</span>
                <span>LARAVEL</span>
                <span class="text-brand-secondary">✦</span>
                <span>NEXT.JS</span>
                <span class="text-brand-secondary">✦</span>
                <span>AI INTEGRATION</span>
                <span class="text-brand-secondary">✦</span>
                <span>UI/UX STRATEGY</span>
                <span class="text-brand-secondary">✦</span>
                <span>SAAS DEVELOPMENT</span>
                <span class="text-brand-secondary">✦</span>
                <span>MOBILE FRIENDLY</span>
                <span class="text-brand-secondary">✦</span>
            </div>
            <!-- Duplicate for loop -->
            <div
                class="marquee-content gap-16 text-editorial font-bold! tracking-[0.5em]! text-[11px]!"
                aria-hidden="true"
            >
                <span>FULL-STACK DEVELOPMENT</span>
                <span class="text-brand-secondary">✦</span>
                <span>LARAVEL EXPERT</span>
                <span class="text-brand-secondary">✦</span>
                <span>NEXT.JS SPECIALIST</span>
                <span class="text-brand-secondary">✦</span>
                <span>AI INTEGRATION</span>
                <span class="text-brand-secondary">✦</span>
                <span>UI/UX STRATEGY</span>
                <span class="text-brand-secondary">✦</span>
            </div>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    // Wait for content to load
    window.addEventListener("DOMContentLoaded", () => {
        // --- Mobile Menu Toggle Logic ---
        const menuToggle = document.getElementById("mobile-menu-toggle");
        const mobileOverlay = document.getElementById("mobile-overlay");
        const bar1 = document.getElementById("bar1");
        const bar2 = document.getElementById("bar2");
        const mobileLinks = document.querySelectorAll(".mobile-link");

        if (menuToggle && mobileOverlay) {
            let isOpen = false;

            const toggleMenu = () => {
                isOpen = !isOpen;
                if (isOpen) {
                    mobileOverlay.classList.remove("translate-x-full");
                    mobileOverlay.classList.add("translate-x-0");
                    bar1?.classList.add("rotate-45", "translate-y-1");
                    bar2?.classList.add("-rotate-45", "-translate-y-1");
                } else {
                    mobileOverlay.classList.remove("translate-x-0");
                    mobileOverlay.classList.add("translate-x-full");
                    bar1?.classList.remove("rotate-45", "translate-y-1");
                    bar2?.classList.remove("-rotate-45", "-translate-y-1");
                }
            };

            menuToggle.addEventListener("click", toggleMenu);
            mobileLinks.forEach((link) => {
                link.addEventListener("click", () => {
                    if (isOpen) toggleMenu();
                });
            });
        }

        // 1. Entrance Animations
        const tl = gsap.timeline({
            defaults: { ease: "power4.out", duration: 1.8 },
        });

        // Slide Reveal Name
        tl.fromTo(
            "#name-line-1",
            { xPercent: -100, opacity: 0 },
            { xPercent: 0, opacity: 1 },
            0.2,
        );

        tl.fromTo(
            "#name-line-2",
            { xPercent: 100, opacity: 0 },
            { xPercent: 0, opacity: 1 },
            0.2,
        );

        // Portrait Reveal
        tl.fromTo(
            "#portrait-img",
            { y: 100, opacity: 0, scale: 1.15 },
            { y: 0, opacity: 1, scale: 1.15, duration: 0.1 },
            1,
        );

        // Corner Blocks & Mobile Content reveal
        tl.fromTo(
            [
                ".corner-block",
                "#mobile-cta",
                "#mobile-socials",
                "#hero-subtitle",
            ],
            { y: 20, opacity: 0 },
            { y: 0, opacity: 1, stagger: 0.1, duration: 1.0 },
            "-=1",
        );

        // 2. Sticky Header Scroll Animation
        gsap.to("#sticky-header", {
            opacity: 1,
            y: 0,
            duration: 0.2,
            ease: "power2.out",
            scrollTrigger: {
                trigger: "section", // Target this section (Hero)
                start: "bottom top", // Trigger when Hero bottom reaches viewport top
                toggleActions: "play none none reverse",
            },
        });

        // 3. Continuous Marquee Animation (GSAP)
        gsap.to(".marquee-content", {
            xPercent: -100,
            repeat: -1,
            duration: 25,
            ease: "none",
        });
    });
</script>
