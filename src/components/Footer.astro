---

---

<footer
    id="contact"
    class="relative min-h-screen bg-brand-bg py-4 px-6 md:py-8 md:px-12 overflow-hidden border-t border-brand-text/5"
>
    <!-- Background Large Typography -->
    <div
        class="absolute inset-0 w-full flex justify-center pointer-events-none select-none z-0"
    >
        <div
            class="h-screen flex items-center justify-center sticky top-0"
            id="footer-bg-container"
        >
            <span
                class="text-[14vw] font-bold text-brand-text/5 leading-none uppercase"
                id="footer-bg-text"
            >
                CONTACT
            </span>
        </div>
    </div>

    <div
        class="max-w-7xl mx-auto relative z-10 flex flex-col h-full min-h-[70vh] justify-between"
    >
        <div>
            <!-- Section Header -->
            <div
                class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-8"
            >
                <div class="overflow-hidden">
                    <h2
                        class="text-brand-accent mb-4 tracking-[0.5em] uppercase"
                        id="footer-tag"
                    >
                        05 / START A CONVERSATION
                    </h2>
                    <h3
                        class="text-6xl md:text-8xl font-bold leading-none tracking-widest uppercase"
                        id="footer-title"
                    >
                        LET'S <br /> COLLABORATE
                    </h3>
                </div>
                <div class="md:text-right max-w-xs overflow-hidden">
                    <p
                        class="text-[11px] leading-relaxed text-brand-text/50 uppercase tracking-widest"
                        id="footer-info"
                    >
                        Available for freelance opportunities and full-time
                        creative roles.
                    </p>
                </div>
            </div>

            <!-- Content Area -->
            <div class="space-y-32">
                <div
                    class="grid grid-cols-1 md:grid-cols-12 gap-12 font-medium border-t border-brand-text/10 pt-20"
                >
                    <!-- Email Contact -->
                    <div
                        class="md:col-span-8 flex flex-col justify-center space-y-8"
                    >
                        <p
                            class="text-xl md:text-3xl leading-relaxed text-brand-text/70"
                        >
                            Got a project in mind, or just want to say hi? <br
                                class="hidden md:block"
                            />
                            Drop me an email, and let's craft something exceptional
                            together.
                        </p>
                        <a
                            href="mailto:nasgunawann@gmail.com"
                            class="group w-full max-w-full flex items-center gap-4 md:gap-6 text-[7vw] md:text-4xl lg:text-5xl font-bold hover:text-brand-accent transition-colors text-brand-text break-all md:break-normal"
                        >
                            nasgunawann@gmail.com
                            <span
                                class="hidden md:inline group-hover:translate-x-4 transition-transform text-brand-accent"
                                >⟶</span
                            >
                        </a>
                    </div>
                </div>

                <!-- Footer Bottom Links -->
                <div
                    class="grid grid-cols-1 md:grid-cols-12 gap-8 border-t border-brand-text/10 pt-8 mt-16"
                >
                    <div class="md:col-span-4 space-y-4 relative">
                        <div
                            class="absolute -left-4 top-0 bottom-0 w-px bg-brand-text/10 hidden md:block"
                        >
                        </div>
                        <span
                            class="text-[11px] font-bold tracking-[0.5em] text-brand-accent uppercase pl-2"
                        >
                            Digital Presence
                        </span>
                        <div class="flex flex-col gap-2 pt-2 pl-2">
                            <a
                                href="https://linkedin.com/in/nasgunawan"
                                target="_blank"
                                class="w-fit text-lg font-bold uppercase tracking-widest text-brand-text/60 hover:text-brand-accent transition-colors"
                                >LinkedIn</a
                            >
                            <a
                                href="https://github.com/nasgunawann"
                                target="_blank"
                                class="w-fit text-lg font-bold uppercase tracking-widest text-brand-text/60 hover:text-brand-accent transition-colors"
                                >GitHub</a
                            >
                            <a
                                href="https://instagram.com/nasgunawann"
                                target="_blank"
                                class="w-fit text-lg font-bold uppercase tracking-widest text-brand-text/60 hover:text-brand-accent transition-colors"
                                >Instagram</a
                            >
                        </div>
                    </div>

                    <div class="md:col-span-4 space-y-4 relative">
                        <div
                            class="absolute -left-4 top-0 bottom-0 w-px bg-brand-text/10 hidden md:block"
                        >
                        </div>
                        <span
                            class="text-[11px] font-bold tracking-[0.5em] text-brand-accent uppercase pl-2"
                        >
                            Location
                        </span>
                        <div class="pt-2 pl-2">
                            <p
                                class="text-[13px] font-bold uppercase tracking-widest text-brand-text/60"
                            >
                                Medan, North Sumatra
                            </p>
                            <p
                                class="text-[13px] font-bold uppercase tracking-widest text-brand-text/40 mt-1"
                            >
                                Indonesia
                            </p>
                        </div>
                    </div>

                    <div
                        class="md:col-span-4 space-y-4 flex flex-col md:items-end relative"
                    >
                        <div
                            class="absolute -left-4 top-0 bottom-0 w-px bg-brand-text/10 hidden md:block"
                        >
                        </div>
                        <span
                            class="text-[11px] font-bold tracking-[0.5em] text-brand-accent uppercase pl-2 md:pr-0"
                        >
                            Navigation
                        </span>
                        <button
                            id="back-to-top"
                            class="pt-2 pl-2 md:pl-0 group flex items-center gap-4 text-lg font-bold uppercase tracking-widest hover:text-brand-accent transition-all text-brand-text/60"
                        >
                            Back to Top <span
                                class="group-hover:-translate-y-2 transition-transform text-2xl leading-none"
                                >↑</span
                            >
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div
            class="flex flex-col md:flex-row justify-between items-center text-center md:text-left gap-6 mt-32 pt-8 border-t border-brand-text/5 text-[10px] font-bold tracking-[0.3em] uppercase text-brand-text/30"
        >
            <p>
                &copy; {new Date().getFullYear()} NASRULLAH GUNAWAN. ALL RIGHTS RESERVED.
            </p>
        </div>
    </div>
</footer>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    window.addEventListener("DOMContentLoaded", () => {
        // 1. Entrance Reveal Header
        const headerElements = ["#footer-tag", "#footer-title", "#footer-info"];
        const tl = gsap.timeline({
            scrollTrigger: {
                trigger: "#contact",
                start: "top 70%",
            },
        });

        tl.from(headerElements, {
            y: 40,
            opacity: 0,
            stagger: 0.2,
            duration: 1.2,
            ease: "power3.out",
        });

        // 2. Background Decorative Text (Lag Scrub)
        gsap.to("#footer-bg-text", {
            scrollTrigger: {
                trigger: "#contact",
                start: "top bottom",
                end: "bottom bottom",
                scrub: 1.5,
            },
            y: 50,
            ease: "none",
        });

        // 3. Back to Top
        const backToTop = document.getElementById("back-to-top");
        if (backToTop) {
            backToTop.addEventListener("click", () => {
                window.scrollTo({
                    top: 0,
                    behavior: "smooth",
                });
            });
        }
    });
</script>
