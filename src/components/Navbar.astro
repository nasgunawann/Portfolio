---
const navItems = [
  { name: 'SYSTEM', href: '#' },
  { name: 'ABOUT.EXE', href: '#about' },
  { name: 'PROJECTS.SH', href: '#projects' },
  { name: 'SKILLS.DLL', href: '#skills' },
  { name: 'LOGOUT', href: '#' },
];
---

<nav class="fixed top-0 left-0 w-full z-50 bg-brand-primary text-brand-bg px-4 py-1 font-mono text-xs flex items-center justify-between shadow-terminal">
  <div class="flex items-center gap-4">
    <span class="font-bold">NAS-OS v1.0.4</span>
    <span class="hidden md:inline text-[10px] opacity-80 uppercase">Status: Online</span>
  </div>
  
  <div class="flex items-center gap-6">
    {navItems.map((item) => (
      <a
        href={item.href}
        class="hover:bg-brand-bg hover:text-brand-primary px-2 py-0.5 transition-colors cursor-pointer"
      >
        {item.name}
      </a>
    ))}
  </div>

  <div class="hidden sm:block text-[10px] font-bold">
    {new Date().toLocaleTimeString()}
  </div>
</nav>
